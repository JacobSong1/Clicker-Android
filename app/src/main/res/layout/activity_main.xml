<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <Button android:id="@+id/btnA"
        android:layout_width="200dp" android:layout_height="wrap_content"
        android:text="A. Captain America" android:layout_margin="8dp"/>

    <Button android:id="@+id/btnB"
        android:layout_width="200dp" android:layout_height="wrap_content"
        android:text="B. Ironman" android:layout_margin="8dp"/>

    <Button android:id="@+id/btnC"
        android:layout_width="200dp" android:layout_height="wrap_content"
        android:text="C. Black Widow" android:layout_margin="8dp"/>

    <Button android:id="@+id/btnD"
        android:layout_width="200dp" android:layout_height="wrap_content"
        android:text="D. Thor" android:layout_margin="8dp"/>

    <EditText
        android:id="@+id/etComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Type your comment here..."
        android:layout_marginTop="24dp"
        android:minLines="3"/>

    <Button
        android:id="@+id/btnComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Comment"
        android:layout_marginTop="8dp"/>

    <TextView android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text=""
        android:textSize="16sp"/>
</LinearLayout>